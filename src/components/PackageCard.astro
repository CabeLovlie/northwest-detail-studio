---
interface Props {
  name: string;
  price: string;
  description: string;
  features: string[];
  duration: string;
  cta: string;
  ctaHref?: string;
  badge?: string;
  highlighted?: boolean;
  images?: string[];
}

const {
  name,
  price,
  description,
  features,
  duration,
  cta,
  ctaHref = '/quote',
  badge,
  highlighted = false,
  images = [],
} = Astro.props;
---

<article
  class:list={[
    'glass-card flex h-full flex-col overflow-hidden transition-all duration-300',
    highlighted && 'border-accent/40 shadow-glow ring-1 ring-accent/20',
  ]}
>
  {
    images.length > 0 && (
      <div class="relative h-40 overflow-hidden sm:h-48">
        <img
          src={images[0]}
          alt=""
          class="h-full w-full object-cover"
          loading="lazy"
        />
        {images.length > 1 && (
          <img
            src={images[1]}
            alt=""
            class="absolute inset-0 h-full w-full object-cover opacity-0 transition-opacity duration-500 group-hover:opacity-100"
            loading="lazy"
          />
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-surface to-transparent" />
      </div>
    )
  }
  <div class="flex flex-1 flex-col p-6 sm:p-8">
    <div class="mb-4 flex items-start justify-between gap-3">
      <h3 class="text-xl font-bold text-text">{name}</h3>
      {
        badge && (
          <span class="shrink-0 rounded-full bg-accent-soft px-3 py-1 text-xs font-semibold text-accent">
            {badge}
          </span>
        )
      }
    </div>
    <p class="mb-2 text-2xl font-bold text-accent">{price}</p>
    <p class="mb-4 text-sm text-text-muted">{description}</p>
    <ul class="mb-6 flex-1 space-y-2 text-sm text-text-muted">
      {
        features.map((feature) => (
          <li class="flex items-start gap-2">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" aria-hidden="true" />
            {feature}
          </li>
        ))
      }
    </ul>
    <p class="mb-4 text-xs text-text-muted">Est. {duration}</p>
    <a
      href={ctaHref}
      class:list={[
        'inline-flex items-center justify-center rounded-lg px-5 py-2.5 text-sm font-semibold transition-all duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent',
        highlighted
          ? 'bg-accent text-background shadow-glow-sm hover:bg-accent-strong'
          : 'border border-white/20 bg-white/5 text-text hover:border-accent/50 hover:bg-accent-soft',
      ]}
    >
      {cta}
    </a>
  </div>
</article>

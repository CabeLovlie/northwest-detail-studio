---
import Base from '../layouts/Base.astro';
import Button from '../components/Button.astro';
import SectionEyebrow from '../components/SectionEyebrow.astro';
import Card from '../components/Card.astro';
import PackageCard from '../components/PackageCard.astro';
import ReviewCard from '../components/ReviewCard.astro';
import FaqItem from '../components/FaqItem.astro';
import BeforeAfterSlider from '../components/BeforeAfterSlider.astro';
import GalleryGrid from '../components/GalleryGrid.astro';
import QuoteForm from '../components/QuoteForm.astro';
import { images } from '../lib/images';
import { site } from '../lib/site';
import Sparkles from '@lucide/astro/icons/sparkles';
import Shield from '@lucide/astro/icons/shield';
import Droplets from '@lucide/astro/icons/droplets';
import ClipboardList from '@lucide/astro/icons/clipboard-list';
import Car from '@lucide/astro/icons/car';
import SprayCan from '@lucide/astro/icons/spray-can';
import Gem from '@lucide/astro/icons/gem';
import Ship from '@lucide/astro/icons/ship';
import MessageSquare from '@lucide/astro/icons/message-square';
import Calendar from '@lucide/astro/icons/calendar';
import CircleCheck from '@lucide/astro/icons/circle-check';
---

<Base title={`${site.name} | Premium Auto Detailing in Auburn, WA`}>
  <!-- 1. Hero -->
  <section class="relative min-h-[85vh] overflow-hidden">
    <img
      src={images.hero}
      alt="Premium detailed vehicle with glossy finish in studio lighting"
      class="absolute inset-0 h-full w-full object-cover"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-background via-background/85 to-background/40" />
    <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-background/30" />

    <div class="container-narrow relative flex min-h-[85vh] items-center px-4 py-20 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <SectionEyebrow class="mb-6">Auburn, WA / South Sound</SectionEyebrow>
        <h1 class="text-4xl font-extrabold leading-tight tracking-tight text-text sm:text-5xl lg:text-6xl">
          {site.tagline}
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-text-muted sm:text-xl">
          Premium interior detailing, paint correction, ceramic coatings, and maintenance care for cars, trucks, boats, and RVs across the South Sound.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <Button href="/quote">Get a Free Quote</Button>
          <Button href="/packages" variant="secondary">View Packages</Button>
        </div>
        <ul class="mt-10 flex flex-wrap gap-x-6 gap-y-3 text-sm text-text-muted" aria-label="Core services">
          <li class="flex items-center gap-2"><Sparkles class="h-4 w-4 text-accent" aria-hidden="true" /> Interior deep cleaning</li>
          <li class="flex items-center gap-2"><Gem class="h-4 w-4 text-accent" aria-hidden="true" /> Paint correction</li>
          <li class="flex items-center gap-2"><Shield class="h-4 w-4 text-accent" aria-hidden="true" /> Ceramic coating</li>
          <li class="flex items-center gap-2"><Ship class="h-4 w-4 text-accent" aria-hidden="true" /> Boat &amp; RV detailing</li>
        </ul>
      </div>

      <aside class="absolute bottom-8 right-4 hidden max-w-xs glass-card p-5 lg:block xl:right-8">
        <p class="text-sm font-bold text-accent">Ceramic Coating Available</p>
        <p class="mt-1 text-sm text-text-muted">Long-term gloss, easier washes, stronger paint protection.</p>
      </aside>
    </div>
  </section>

  <!-- 2. Trust / Proof Bar -->
  <section class="border-y border-white/10 bg-surface" aria-label="Trust highlights">
    <div class="container-narrow px-4 py-8 sm:px-6 lg:px-8">
      <p class="mb-6 text-center text-sm font-semibold text-text sm:text-base">
        Built for daily drivers, weekend cars, work trucks, boats, and RVs.
      </p>
      <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <li class="flex items-start gap-3 text-sm text-text-muted">
          <Droplets class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true" />
          Paint-safe wash process
        </li>
        <li class="flex items-start gap-3 text-sm text-text-muted">
          <SprayCan class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true" />
          Stain &amp; odor treatment
        </li>
        <li class="flex items-start gap-3 text-sm text-text-muted">
          <Shield class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true" />
          Ceramic protection
        </li>
        <li class="flex items-start gap-3 text-sm text-text-muted">
          <ClipboardList class="mt-0.5 h-5 w-5 shrink-0 text-accent" aria-hidden="true" />
          Clear condition-based quotes
        </li>
      </ul>
    </div>
  </section>

  <!-- 3. Before / After Preview -->
  <section id="before-after" class="section-padding">
    <div class="container-narrow">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <SectionEyebrow class="mb-4 inline-block">Results</SectionEyebrow>
        <h2 class="text-3xl font-bold text-text sm:text-4xl">See the Difference Before You Book</h2>
        <p class="mt-4 text-text-muted">
          From stained interiors to dull paint and brake-dusted wheels, every service is built around visible results.
        </p>
      </div>
      <div class="grid gap-8 lg:grid-cols-3">
        <BeforeAfterSlider
          index={0}
          title="Interior Reset"
          beforeSrc={images.dirtyInterior}
          afterSrc={images.suvInteriorClean}
          beforeAlt="Dirty vehicle interior with stains and buildup"
          afterAlt="Clean SUV interior after deep cleaning"
          description="Stains, crumbs, dust, and daily-driver buildup removed through deep interior cleaning."
        />
        <BeforeAfterSlider
          index={1}
          title="Paint Correction"
          beforeSrc={images.paintBad}
          afterSrc={images.paintGood}
          beforeAlt="Dull paint with swirls and haze before correction"
          afterAlt="Restored glossy paint after machine polishing"
          description="Dull, hazy paint restored with machine polishing and proper finishing."
        />
        <BeforeAfterSlider
          index={2}
          title="Wheel & Tire Detail"
          beforeSrc={images.wheelBrakeDust}
          afterSrc={images.wheelGlossy}
          beforeAlt="Wheel covered in brake dust and grime"
          afterAlt="Clean glossy wheel and dressed tire"
          description="Brake dust, grime, and dull tires cleaned and dressed for a finished look."
        />
      </div>
    </div>
  </section>

  <!-- 4. Services -->
  <section id="services" class="section-padding bg-surface">
    <div class="container-narrow">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <SectionEyebrow class="mb-4 inline-block">Services</SectionEyebrow>
        <h2 class="text-3xl font-bold text-text sm:text-4xl">Detailing Services Built Around Your Vehicle's Condition</h2>
        <p class="mt-4 text-text-muted">
          Whether your vehicle needs a quick refresh, a serious interior reset, or long-term paint protection, we'll help you choose the right service.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          [
            {
              title: 'Interior Detailing',
              img: images.dashWiping,
              alt: 'Detailer wiping dashboard during interior detail',
              desc: 'Deep vacuuming, steam cleaning, stain treatment, leather and vinyl care, and odor reduction for a cleaner, more comfortable cabin.',
            },
            {
              title: 'Exterior Detailing',
              img: images.foam,
              alt: 'Foam wash on vehicle exterior',
              desc: 'Foam wash, hand wash, decontamination, trim care, wheels, tires, and paint-safe finishing for a clean, glossy exterior.',
            },
            {
              title: 'Paint Correction',
              img: images.polishCloseup,
              alt: 'Machine polishing close-up',
              desc: 'Machine polishing to reduce swirls, haze, oxidation, and light defects while restoring depth and clarity to the paint.',
            },
            {
              title: 'Ceramic Coating',
              img: images.ceramicCoatingCloseUpApplication,
              alt: 'Ceramic coating application close-up',
              desc: 'Long-term paint protection that adds gloss, improves water behavior, and makes maintenance washes easier.',
            },
            {
              title: 'Boat & RV Detailing',
              img: images.cleanBoat,
              alt: 'Clean detailed boat',
              desc: 'Large-format detailing for boats, RVs, gelcoat, interiors, seasonal cleanup, and oxidation-prone surfaces.',
            },
            {
              title: 'Maintenance Details',
              img: images.cleanTruck,
              alt: 'Clean truck after maintenance detail',
              desc: 'Recurring care for vehicles that already look good and need to stay clean, protected, and easy to maintain.',
            },
          ].map((service) => (
            <Card>
              <img src={service.img} alt={service.alt} class="mb-5 h-48 w-full rounded-xl object-cover" loading="lazy" />
              <h3 class="mb-3 text-xl font-bold text-text">{service.title}</h3>
              <p class="text-sm leading-relaxed text-text-muted">{service.desc}</p>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 5. Packages -->
  <section id="packages" class="section-padding">
    <div class="container-narrow">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <SectionEyebrow class="mb-4 inline-block">Packages</SectionEyebrow>
        <h2 class="text-3xl font-bold text-text sm:text-4xl">Choose the Detail That Fits Your Vehicle</h2>
        <p class="mt-4 text-text-muted">
          Simple packages make it easier to choose, and condition-based quotes keep expectations clear.
        </p>
      </div>
      <div class="grid gap-6 lg:grid-cols-2 xl:grid-cols-4">
        <PackageCard
          name="Refresh Detail"
          price="Starting at $149"
          description="Best for maintained vehicles that need a clean reset."
          features={['Hand wash', 'Interior vacuum', 'Surface wipe-down', 'Windows', 'Wheels and tires', 'Light interior cleaning']}
          duration="2–3 hours"
          cta="Request Refresh Quote"
        />
        <PackageCard
          name="Deep Clean Detail"
          price="Starting at $249"
          description="Best for daily drivers, family vehicles, pet hair, spills, stains, and neglected interiors."
          features={['Full interior detail', 'Steam cleaning', 'Stain treatment', 'Upholstery or leather care', 'Exterior hand wash', 'Clay treatment', 'Paint sealant', 'Trim and tire dressing']}
          duration="4–6 hours"
          cta="Request Deep Clean Quote"
          badge="Most Popular"
          highlighted={true}
        />
        <PackageCard
          name="Signature Detail"
          price="Starting at $399"
          description="Best for vehicles that need a full interior and exterior reset."
          features={['Full interior deep clean', 'Exterior decontamination', 'One-step polish', 'Paint sealant', 'Wheel and tire detail', 'Final inspection', 'Care recommendations']}
          duration="6–8 hours"
          cta="Request Signature Quote"
        />
      </div>

      <article class="mt-8 overflow-hidden rounded-2xl border border-accent/40 bg-surface shadow-glow ring-1 ring-accent/20">
        <div class="grid lg:grid-cols-2">
          <div class="relative min-h-[240px] lg:min-h-full">
            <img src={images.ceramicCoatingReflection} alt="Glossy ceramic-coated paint reflection" class="absolute inset-0 h-full w-full object-cover" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-r from-transparent to-surface lg:bg-gradient-to-r lg:from-transparent lg:to-surface" />
          </div>
          <div class="flex flex-col justify-center p-8 sm:p-10">
            <span class="mb-3 inline-flex w-fit rounded-full bg-accent-soft px-3 py-1 text-xs font-semibold text-accent">Premium Protection</span>
            <h3 class="text-2xl font-bold text-text">Ceramic Coating</h3>
            <p class="mt-2 text-xl font-bold text-accent">Starting at $699</p>
            <p class="mt-3 text-sm text-text-muted">
              Best for drivers who want longer-lasting protection, deeper gloss, and easier washing.
            </p>
            <ul class="mt-4 space-y-2 text-sm text-text-muted">
              <li class="flex items-start gap-2"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" />Paint decontamination</li>
              <li class="flex items-start gap-2"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" />Gloss enhancement polish</li>
              <li class="flex items-start gap-2"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" />Surface prep &amp; ceramic application</li>
              <li class="flex items-start gap-2"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent" />Cure guidance &amp; maintenance recommendations</li>
            </ul>
            <div class="mt-6">
              <Button href="/ceramic-coating">Explore Ceramic Coating</Button>
            </div>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- 6. Recommendation Section -->
  <section class="section-padding bg-surface">
    <div class="container-narrow">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <SectionEyebrow class="mb-4 inline-block">Guidance</SectionEyebrow>
        <h2 class="text-3xl font-bold text-text sm:text-4xl">Not Sure What Your Vehicle Needs?</h2>
        <p class="mt-4 text-text-muted">
          Start with the condition of your vehicle and we'll point you toward the right service.
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {
          [
            { prompt: 'My car is mostly clean', pkg: 'Refresh Detail', desc: 'Best for regular upkeep, light dust, and vehicles that are already maintained.', href: '/quote?service=refresh', icon: Car },
            { prompt: 'My interior needs help', pkg: 'Deep Clean Detail', desc: 'Best for stains, crumbs, pet hair, spills, odor, and family vehicles.', href: '/quote?service=deep-clean', icon: Sparkles },
            { prompt: 'My paint looks dull or swirled', pkg: 'Paint Correction', desc: 'Best for haze, swirl marks, oxidation, and paint that has lost its depth.', href: '/quote?service=paint-correction', icon: Gem },
            { prompt: 'I want long-term protection', pkg: 'Ceramic Coating', desc: 'Best for gloss, protection, easier washes, and long-term maintenance.', href: '/ceramic-coating', icon: Shield },
          ].map((item) => (
            <a href={item.href} class="glass-card group block p-6 transition-all hover:border-accent/30 hover:shadow-glow-sm">
              <item.icon class="mb-4 h-6 w-6 text-accent" aria-hidden="true" />
              <p class="text-sm italic text-text-muted">{item.prompt}</p>
              <h3 class="mt-2 text-lg font-bold text-text group-hover:text-accent">{item.pkg}</h3>
              <p class="mt-2 text-sm text-text-muted">{item.desc}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 7. Featured Transformation -->
  <section class="section-padding">
    <div class="container-narrow">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <SectionEyebrow class="mb-4 inline-block">Sample Transformation</SectionEyebrow>
        <h2 class="text-3xl font-bold text-text sm:text-4xl">Featured Transformation: Family SUV Interior Reset</h2>
        <p class="mt-4 text-text-muted">A deep clean built for the reality of daily driving.</p>
        <p class="mt-2 text-xs italic text-text-muted">Sample transformation — not a real customer case study.</p>
      </div>

      <div class="mb-8 grid grid-cols-3 gap-3 sm:gap-4">
        <img src={images.dirtyInterior} alt="Dirty SUV interior before cleaning" class="aspect-[4/3] rounded-xl object-cover" loading="lazy" />
        <img src={images.interiorVacuuming} alt="Deep vacuuming during interior reset" class="aspect-[4/3] rounded-xl object-cover" loading="lazy" />
        <img src={images.suvInteriorClean} alt="Clean SUV interior after reset" class="aspect-[4/3] rounded-xl object-cover" loading="lazy" />
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        <Card padding={true}>
          <h3 class="mb-3 text-lg font-bold text-accent">The Condition</h3>
          <p class="text-sm text-text-muted">Pet hair, crumbs, dust, light staining, and odor buildup from daily use.</p>
        </Card>
        <Card padding={true}>
          <h3 class="mb-3 text-lg font-bold text-accent">The Service</h3>
          <p class="text-sm text-text-muted">Deep vacuuming, steam cleaning, upholstery extraction, stain treatment, and interior surface care.</p>
        </Card>
        <Card padding={true}>
          <h3 class="mb-3 text-lg font-bold text-accent">The Result</h3>
          <p class="text-sm text-text-muted">A cleaner, fresher cabin that feels comfortable again for commuting, errands, and family drives.</p>
        </Card>
      </div>
      <div class="mt-8 text-center">
        <Button href="/quote">Get a Similar Reset</Button>
      </div>
    </div>
  </section>

  <!-- 8. Why Choose Us -->
  <section class="section-padding bg-surface">
    <div class="container-narrow">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <SectionEyebrow class="mb-4 inline-block">Why Us</SectionEyebrow>
        <h2 class="text-3xl font-bold text-text sm:text-4xl">Clear Recommendations. Careful Work. Visible Results.</h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-2">
        {
          [
            { title: 'Condition-Based Quotes', desc: 'No vague one-size-fits-all pricing. Each quote is based on vehicle size, condition, and goals.', img: images.inspectionLight, alt: 'Paint inspection under specialized lighting' },
            { title: 'Paint-Safe Process', desc: 'Careful wash methods, soft tools, and proper products for paint, trim, leather, vinyl, and glass.', img: images.underLights, alt: 'Vehicle under studio lighting during detail' },
            { title: 'Results You Can See', desc: 'Before/after visuals, walkthroughs, and clear expectations before the work starts.', img: images.detailerAtWork01, alt: 'Detailer carefully working on vehicle' },
            { title: 'Protection That Lasts', desc: 'Sealants and coatings designed to keep vehicles cleaner, glossier, and easier to maintain.', img: images.waterBeading, alt: 'Water beading on protected paint surface' },
          ].map((item) => (
            <article class="glass-card group overflow-hidden">
              <div class="relative h-44 overflow-hidden">
                <img src={item.img} alt={item.alt} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                <div class="absolute inset-0 bg-gradient-to-t from-surface to-transparent" />
              </div>
              <div class="p-6">
                <h3 class="mb-2 text-lg font-bold text-text">{item.title}</h3>
                <p class="text-sm text-text-muted">{item.desc}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 9. Process -->
  <section class="section-padding">
    <div class="container-narrow">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <SectionEyebrow class="mb-4 inline-block">Process</SectionEyebrow>
        <h2 class="text-3xl font-bold text-text sm:text-4xl">A Simple Process From Quote to Final Walkthrough</h2>
      </div>

      <div class="grid gap-8 lg:grid-cols-2">
        <ol class="relative space-y-8 border-l-2 border-accent/30 pl-8">
          {
            [
              { step: '1', title: 'Send Vehicle Details', desc: "Tell us the vehicle type, condition, and services you're interested in.", icon: MessageSquare },
              { step: '2', title: 'Get a Clear Recommendation', desc: "We'll recommend the right package or add-ons based on your goals.", icon: ClipboardList },
              { step: '3', title: 'Detail Day', desc: 'Your vehicle gets cleaned, restored, and protected using a careful step-by-step process.', icon: Calendar },
              { step: '4', title: 'Final Walkthrough', desc: 'We review the work with you and share care tips for keeping it clean longer.', icon: CircleCheck },
            ].map((item) => (
              <li class="relative">
                <span class="absolute -left-[41px] flex h-8 w-8 items-center justify-center rounded-full bg-accent text-sm font-bold text-background">{item.step}</span>
                <h3 class="flex items-center gap-2 text-lg font-bold text-text">
                  <item.icon class="h-5 w-5 text-accent" aria-hidden="true" />
                  {item.title}
                </h3>
                <p class="mt-2 text-sm text-text-muted">{item.desc}</p>
              </li>
            ))
          }
        </ol>

        <div class="grid grid-cols-2 gap-3">
          <img src={images.detailerAtWork02} alt="Detailer working on vehicle exterior" class="aspect-square rounded-xl object-cover" loading="lazy" />
          <img src={images.detailerAtWork03} alt="Detailer polishing vehicle paint" class="aspect-square rounded-xl object-cover" loading="lazy" />
          <img src={images.drying} alt="Drying vehicle after detail" class="aspect-square rounded-xl object-cover" loading="lazy" />
          <img src={images.pressureWash} alt="Pressure washing vehicle" class="aspect-square rounded-xl object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- 10. Gallery Preview -->
  <section id="gallery" class="section-padding bg-surface">
    <div class="container-narrow">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <SectionEyebrow class="mb-4 inline-block">Gallery</SectionEyebrow>
        <h2 class="text-3xl font-bold text-text sm:text-4xl">Recent Work Style Gallery</h2>
        <p class="mt-4 text-text-muted">
          A visual preview of the services Northwest Detail Studio is built around.
        </p>
      </div>
      <GalleryGrid limit={12} />
      <div class="mt-8 text-center">
        <Button href="/gallery" variant="secondary">View Full Gallery</Button>
      </div>
    </div>
  </section>

  <!-- 11. Reviews -->
  <section id="reviews" class="section-padding">
    <div class="container-narrow">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <SectionEyebrow class="mb-4 inline-block">Reviews</SectionEyebrow>
        <h2 class="text-3xl font-bold text-text sm:text-4xl">What Customers Notice First</h2>
        <p class="mt-2 text-xs italic text-text-muted">Sample reviews — not real Google reviews.</p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2">
        <ReviewCard
          quote="My SUV felt brand new again. They pulled out stains and pet hair I thought were permanent, and the whole interior felt fresher when I picked it up."
          service="Interior Deep Clean"
        />
        <ReviewCard
          quote="The paint correction made a huge difference. The black paint looked deeper, the swirls were reduced, and the finish had that mirror-like look again."
          service="Paint Correction"
        />
        <ReviewCard
          quote="The ceramic coating made washing my truck so much easier. Water beads right off and the gloss still looks great weeks later."
          service="Ceramic Coating"
        />
        <ReviewCard
          quote="Clear communication, clean work, and no pressure. They explained what my car needed and what could wait."
          service="Full Detail"
        />
      </div>
    </div>
  </section>

  <!-- 12. FAQ -->
  <section id="faq" class="section-padding bg-surface">
    <div class="container-narrow">
      <div class="mx-auto mb-12 max-w-3xl text-center">
        <SectionEyebrow class="mb-4 inline-block">FAQ</SectionEyebrow>
        <h2 class="text-3xl font-bold text-text sm:text-4xl">Detailing Questions, Answered</h2>
      </div>
      <div class="mx-auto max-w-3xl glass-card px-6 sm:px-8">
        <FaqItem index={0} question="How long does a detail take?" answer="Most details take 2–6 hours depending on vehicle size, condition, and selected services. Larger vehicles, heavy pet hair, stains, and paint correction can take longer." />
        <FaqItem index={1} question="Do you remove pet hair?" answer="Yes. Heavy pet hair may require an add-on because it takes extra time to remove properly." />
        <FaqItem index={2} question="What is paint correction?" answer="Paint correction uses machine polishing to reduce swirl marks, haze, oxidation, and light scratches. It helps restore depth, gloss, and clarity to the paint." />
        <FaqItem index={3} question="Is ceramic coating worth it?" answer="Ceramic coating can be a great option if you want longer-lasting protection, deeper gloss, and easier maintenance washes." />
        <FaqItem index={4} question="Do you need access to water or power?" answer="Mobile appointments may require access to water and power unless otherwise arranged. Drop-off appointments can be completed at the studio." />
        <FaqItem index={5} question="Can you detail boats and RVs?" answer="Yes. Boats and RVs are quoted based on size, condition, access, and oxidation level." />
        <FaqItem index={6} question="Do I need to choose a package before requesting a quote?" answer="No. Send vehicle details and photos, and we'll recommend the right package based on your goals." />
      </div>
    </div>
  </section>

  <!-- 13. Final CTA / Quote Form -->
  <section class="section-padding">
    <div class="container-narrow">
      <QuoteForm id="quote" showHeading={true} />
    </div>
  </section>
</Base>
